
import React, { useRef, useMemo, useEffect } from 'react';
import { useFrame, useThree } from '@react-three/fiber';
import { PerspectiveCamera } from '@react-three/drei';
import * as THREE from 'three';

/**
 * ============================================================================
 * ARCHITECTURAL REFERENCE: SINGLE-CANVAS SPLIT SCREEN SYSTEM
 * ============================================================================
 * 
 * CORE PHILOSOPHY: "THE HTML STENCIL"
 * ----------------------------------------------------------------------------
 * Problem: Calculating viewport dimensions (x, y, width, height) in JavaScript 
 * is fragile. It breaks easily with window resizing, mobile safe areas, 
 * and varying aspect ratios.
 * 
 * Solution: We do NOT calculate pixels in JS. Instead, we use the browser's 
 * native layout engine (CSS Grid/Flexbox) to define the layout using empty 
 * HTML <div> elements rendered behind the canvas.
 * 
 * The Renderer Loop:
 * 1. Disable default auto-clear (so we can draw multiple times).
 * 2. Clear the screen ONCE.
 * 3. Loop through active players.
 * 4. Measure the corresponding HTML <div> for that player.
 * 5. Set the GPU Scissor (clipping region) to match that div.
 * 6. Render the scene using that player's specific camera.
 */

// Types for clarity
type PlayerId = number;
type CameraRef = THREE.PerspectiveCamera | null;
type ViewRef = HTMLDivElement | null;

interface SplitScreenManagerProps {
    playerCount: number; // 1 to 4
    layout: 'horizontal' | 'vertical' | 'grid'; // How to arrange the viewports
}

/**
 * 1. THE VIEWPORT RENDERER (The Engine Room)
 * This component hooks into the R3F render loop and hijacks the drawing process.
 */
const ViewportRenderer: React.FC<{
    cameraRefs: React.MutableRefObject<CameraRef[]>; // Array of cameras (one per player)
    viewRefs: React.MutableRefObject<ViewRef[]>;     // Array of HTML Divs (one per player)
    count: number;                                   // How many players active
}> = ({ cameraRefs, viewRefs, count }) => {
    
    // Priority 1 ensures this runs AFTER game logic but BEFORE standard rendering would happen
    useFrame(({ gl, scene }, delta) => {
        
        // A. PREPARATION
        // --------------------------------------------------------------------
        // Disable automatic clearing. Normally, Three.js wipes the screen before 
        // every render. Since we render 4 times per frame, we'd wipe out P1's 
        // view when drawing P2 if this was true.
        gl.autoClear = false;
        
        // We manually clear color/depth/stencil buffers once at the start of the frame.
        gl.clear();

        // Get dimensions of the Canvas element itself to calculate relative positions.
        const canvasRect = gl.domElement.parentElement?.getBoundingClientRect();
        if (!canvasRect) return;

        // B. THE RENDER LOOP
        // --------------------------------------------------------------------
        for (let i = 0; i < count; i++) {
            const cam = cameraRefs.current[i];
            const div = viewRefs.current[i];

            // Safety check: Ensure both the camera and the DOM element exist
            if (cam && div) {
                
                // 1. MEASUREMENT (The Stencil)
                // Ask the browser: "Where is this player's box right now?"
                const rect = div.getBoundingClientRect();

                // 2. COORDINATE CONVERSION (The "Gotcha")
                // HTML coordinates start at Top-Left.
                // WebGL coordinates start at Bottom-Left.
                // We must flip the Y-axis.
                const glBottom = canvasRect.bottom - rect.bottom;
                const glLeft = rect.left - canvasRect.left;

                // 3. SCISSOR (Clipping)
                // "Only allow pixels to change within this rectangle"
                gl.setScissorTest(true);
                gl.setScissor(glLeft, glBottom, rect.width, rect.height);

                // 4. VIEWPORT (Mapping)
                // "Map the camera's -1 to +1 coordinates to this rectangle"
                gl.setViewport(glLeft, glBottom, rect.width, rect.height);

                // 5. ASPECT RATIO CORRECTION
                // Since the viewport shape changes (squarish in grid, wide in single),
                // we must update the camera's aspect ratio to prevent stretching.
                // Note: We avoid updating if aspect hasn't changed significantly to save CPU.
                const newAspect = rect.width / rect.height;
                if (Math.abs(cam.aspect - newAspect) > 0.01) {
                    cam.aspect = newAspect;
                    cam.updateProjectionMatrix();
                }

                // 6. DRAW
                gl.render(scene, cam);
            }
        }

        // C. CLEANUP
        // Restore scissor test to false so UI or other global effects aren't clipped
        gl.setScissorTest(false);
        
    }, 1); // Render Priority: 1

    return null;
};

/**
 * 2. THE LAYOUT COMPONENT (The Skeleton)
 * This component sets up the DOM Grid and instantiates the Cameras.
 */
export const SplitScreenReference: React.FC<SplitScreenManagerProps> = ({ playerCount, layout }) => {
    
    // Mutable references to hold our Cameras and Divs. 
    // We use refs because we don't want to re-render the React tree just because a camera moved.
    const cameraRefs = useRef<CameraRef[]>([]);
    const viewRefs = useRef<ViewRef[]>([]);

    // A. CSS GRID LOGIC
    // We use Tailwind classes to define the layout.
    // The JavaScript doesn't calculate sizes; it just applies classes.
    const getContainerClass = () => {
        if (playerCount === 1) return "w-full h-full"; // Full Screen
        
        if (playerCount === 2) {
            // Split Screen
            return layout === 'horizontal' 
                ? "flex flex-col-reverse w-full h-full" // Top/Bottom
                : "flex flex-row w-full h-full";        // Left/Right
        }
        
        // 3-4 Players: 2x2 Grid
        return "grid grid-cols-2 grid-rows-2 w-full h-full";
    };

    return (
        <div className="absolute inset-0 w-full h-full">
            
            {/* 
               LAYER 1: THE HTML STENCIL 
               This is an invisible grid of divs that sits behind the canvas.
               The ViewportRenderer measures these divs to decide where to draw.
            */}
            <div className={`absolute inset-0 pointer-events-none ${getContainerClass()}`}>
                {Array.from({ length: playerCount }).map((_, i) => (
                    <div 
                        key={`viewport-stencil-${i}`}
                        ref={(el) => { viewRefs.current[i] = el; }}
                        className="relative w-full h-full border-r border-b border-white/10" // Optional borders
                    />
                ))}
            </div>

            {/* 
               LAYER 2: THE CAMERAS
               We spawn 'N' cameras, but we do NOT attach them to the default render loop.
               Instead, we store their references in `cameraRefs`.
            */}
            {Array.from({ length: playerCount }).map((_, i) => (
                <PerspectiveCamera
                    key={`cam-${i}`}
                    makeDefault={i === 0} // Only P1 is "default" for simple Drei helpers
                    manual // CRITICAL: Tells R3F "Do not auto-render this camera"
                    ref={(ref) => { 
                        cameraRefs.current[i] = ref;
                        
                        // Layering Logic (Optional but recommended):
                        // P1 sees Layer 1, P2 sees Layer 2, etc.
                        // This allows hiding P2's HUD from P1's screen.
                        if (ref) {
                            ref.layers.enable(0);     // See World
                            ref.layers.enable(i + 1); // See Own UI
                        }
                    }}
                    position={[0, 10, 50]} // Default start pos
                />
            ))}

            {/* 
               LAYER 3: THE RENDERER
               Passes the refs to the loop logic defined above.
            */}
            <ViewportRenderer 
                cameraRefs={cameraRefs} 
                viewRefs={viewRefs} 
                count={playerCount} 
            />
            
        </div>
    );
};
